<!DOCTYPE html>
<html>
<head>
    <title>Expense Tracker</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- ADD THIS -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <nav class="navbar navbar-dark bg-dark mb-4">
    <div class="container">
        <span class="navbar-brand">
            Expense Tracker
        </span>
        <div class="d-flex align-items-center">
            <span class="text-white me-3">
                👤 Welcome, <%= userName %>
            </span>
            <a href="/logout" class="btn btn-outline-light btn-sm">
                Logout
            </a>
        </div>
    </div>
    </nav>
    <div class="container mt-5">

        <h1>All Expenses</h1>

        <a href="/expenses/add" class="btn btn-success mb-3">
            Add Expense
        </a>
        <div class="alert alert-success">
            <div class="card mb-3">
                <div class="card-body">
                    <h4>Total Expenses: ₹<%= total %></h4>
                </div>
            </div>
        </div>
        <br><br>


        <form action="/expenses/budget" method="POST">
        <div class="mb-3">
        <label>Monthly Budget</label>
        <input
            type="number"
            name="amount"
            class="form-control"
            required>
        </div>
        <button
        class="btn btn-primary">
        Save Budget
        </button>
        </form>

        <div class="card mt-3 p-3">

    <h4>Budget Summary</h4>
    <p>
        Budget:
        ₹<%= budget ? budget.amount : 0 %>
    </p>
    <p>
        Spent:
        ₹<%= total %>
    </p>
    <p>
        Remaining:
        ₹<%= remaining %>
    </p>
    </div>


    <%let percentage = 0;
    if (budget && budget.amount > 0) {
    percentage = (total / budget.amount) * 100;
    }
    if (percentage > 100) {
        percentage = 100;
    }
    %>
    <div class="progress mt-3">
        <div
            class="progress-bar"
            role="progressbar"
            style="width:<%= percentage %>%">
            <%= Math.round(percentage) %>%
         </div>
    </div>

    
        <form action="/expenses/search" method="GET">
            <div class="input-group mb-3">
                <input
                    type="text"
                    name="keyword"
                    class="form-control"
                    placeholder="Search Expense">
                <button
                    class="btn btn-primary"
                    type="submit">
                    Search
                </button>
            </div>
        </form>
        <br>

        <table class="table table-striped">
            <tr>
                <th>Title</th>
                <th>Amount</th>
                <th>Category</th>
                <th>Delete</th>
                <th>Edit</th>
                <th>Date</th>
            </tr>

            <% expenses.forEach(expense => { %>
                <tr>
                    <td><%= expense.title %></td>
                    <td><%= expense.amount %></td>
                    <td><%= expense.category %></td>
                    <td>
                        <form action="/expenses/delete/<%= expense._id %>" method="POST">
                            <button class="btn btn-danger">Delete</button>
                        </form>
                    </td>
                    <td>
                        <a href="/expenses/edit/<%= expense._id %>" class="btn btn-primary">Edit</a>
                    </td>
                    <td><%= expense.date.toLocaleDateString("en-IN") %></td>
                </tr>
            <% }) %>
        </table>

        <!-- ADD THIS -->
        <div style="width: 400px; margin: 30px auto;">
            <h4 class="text-center">Spending by Category</h4>
            <canvas id="expenseChart"></canvas>
        </div>

    </div>

    <!-- ADD THIS -->
    <script>
        const labels = <%- JSON.stringify(chartLabels) %>;
        const data = <%- JSON.stringify(chartData) %>;

        const ctx = document.getElementById("expenseChart").getContext("2d");
        new Chart(ctx, {
            type: "pie",
            data: {
                labels: labels,
                datasets: [{
                    data: data,
                    backgroundColor: [
                        "#FF6384",
                        "#36A2EB",
                        "#FFCE56",
                        "#4BC0C0",
                        "#9966FF",
                        "#FF9F40"
                    ]
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        position: "bottom"
                    }
                }
            }
        });
    </script>

</body>
</html>